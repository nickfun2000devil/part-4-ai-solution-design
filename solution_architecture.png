@font-face { font-family: Anthropicons-Variable; src: url("https://assets-p=
roxy.anthropic.com/claude-ai/v2/assets/v1/c0f671921-CQQW7vGw.woff2") format=
("woff2-variations"); font-weight: 400 700; font-display: block; }

@keyframes dframe-dot-pulse {=20
  0%, 5% { opacity: 0.3; animation-timing-function: cubic-bezier(0.165, 0.8=
4, 0.44, 1); }
  15%, 25% { opacity: 1; animation-timing-function: cubic-bezier(0.165, 0.8=
4, 0.44, 1); }
  65%, 100% { opacity: 0.3; }
}

.dframe-dot { width: 2px; height: 2px; border-radius: 9999px; background: h=
sl(var(--text-400)); animation: 1.8s linear 0s infinite normal none running=
 dframe-dot-pulse; }

.dframe-dot:nth-child(2) { animation-delay: 0.2s; }

.dframe-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes check-spin-in {=20
  0% { transform: translateY(8px) rotate(-270deg) scale(0); }
  100% { transform: translateY(0px) rotate(0deg) scale(1); }
}

.check-spin-in { animation: 0.33s cubic-bezier(0.4, 0, 0.2, 1) 0s 1 normal =
both running check-spin-in; }

@media (prefers-reduced-motion: reduce) {
  .dframe-dot, .check-spin-in { animation: auto ease 0s 1 normal none runni=
ng none; }
}

:root { --dot-ready: hsl(210 80% 55%); --dot-awaiting: var(--extended-yello=
w); }

[data-mode=3D"dark"] { --dot-ready: hsl(210 85% 65%); }

